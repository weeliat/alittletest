apiVersion: v1
kind: Service
metadata:
  name: vault-kmip
  namespace: vault  # Ensure this matches your Vault namespace
spec:
  selector:
    app.kubernetes.io/name: vault
    component: server
    vault-active: "true"
  ports:
    - name: kmip
      port: 5696
      targetPort: 5696
      protocol: TCP
