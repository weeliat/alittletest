apiVersion: v1
kind: Service
metadata:
  name: vault-kmip
  namespace: vault
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: vault
    app.kubernetes.io/instance: vault  # Add this if your helm release name is 'vault'
    component: server
  ports:
    - name: kmip
      port: 5696
      targetPort: 5696
      protocol: TCP
